[flake8]
max-line-length = 100
# E203 and W503 conflict with black's formatting choices.
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    venv
per-file-ignores =
    # Embedded shell/JS/HTML lives inside string literals where line length
    # isn't meaningfully controllable and `# noqa` can't be placed.
    csproxy/templates.py:E501
    csproxy/completion.py:E501
    # Import-contract tests deliberately import symbols to assert importability;
    # the unused-import warning is expected and intentional there.
    tests/test_api_contracts.py:F401
    tests/test_installation.py:F401
